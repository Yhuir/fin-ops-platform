# fin-ops OA integration
FIN_OPS_OA_BASE_URL=https://oa.company.com
FIN_OPS_OA_USER_INFO_PATH=/system/user/getInfo
FIN_OPS_OA_REQUIRED_PERMISSION=finops:app:view
FIN_OPS_OA_REQUEST_TIMEOUT_MS=5000
FIN_OPS_OA_SESSION_CACHE_TTL_SECONDS=30

# Optional allow-list fallback
FIN_OPS_ALLOWED_USERNAMES=YNSYLP005
FIN_OPS_READONLY_EXPORT_USERNAMES=
FIN_OPS_ADMIN_USERNAMES=YNSYLP005
FIN_OPS_ALLOWED_ROLES=

# Optional automatic OA menu-role sync on access-control save
FIN_OPS_OA_ROLE_SYNC_ENABLED=0
FIN_OPS_OA_ROLE_SYNC_HOST=127.0.0.1
FIN_OPS_OA_ROLE_SYNC_PORT=3306
FIN_OPS_OA_ROLE_SYNC_DATABASE=smart_oa
FIN_OPS_OA_ROLE_SYNC_USERNAME=root
FIN_OPS_OA_ROLE_SYNC_PASSWORD=
FIN_OPS_OA_ROLE_SYNC_CONNECT_TIMEOUT_SECONDS=5
FIN_OPS_OA_ROLE_SYNC_READONLY_ROLE_KEY=finops_read_export
FIN_OPS_OA_ROLE_SYNC_FULL_ACCESS_ROLE_KEY=finops_full_access
FIN_OPS_OA_ROLE_SYNC_ADMIN_ROLE_KEY=finops_admin

# fin-ops frontend
VITE_APP_BASE_PATH=/fin-ops/

# Business Mongo and other runtime settings are configured separately.
